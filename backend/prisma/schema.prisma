// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  chats     Chat[]
}

model Chat {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  response  String
  type      String // general | symptom | medicine | document
  provider  String
  model     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
